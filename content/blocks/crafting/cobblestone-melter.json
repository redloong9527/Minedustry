{
  "type": "GenericCrafter",
  "name": "Cobblestone Melter",
  "description": "Melts cobblestone into lava.",
  "health": 1200,
  "size": 2,
  "buildTime": 300,
  "hasItems": true,
  "hasLiquid": true,
  "hasPower": true,
  "itemCapacity": 20,
  "liquidCapacity": 30,
  "category": "crafting",
  "craftTime": 30,
  "consumes": {
    "items": ["minedustry-cobblestone-item/1"],
    "power": 1.2
    },
  "outputLiquids": ["minedustry-lava/0.133333333333"],
  "requirements": ["copper/30","lead/10","graphite/25","silicon/15"],
  "drawer": {
    "type": "DrawMulti",
    "drawers": [
      {
        "type": "drawRegion",
        "suffix": "-bottom",
        "layer": 1
      },
      {
        "type": "DrawLiquidTile",
        "drawLiquid": "minedustry-lava",
        "layer": 2,
        "padLeft": 2,
        "padRight": 2,
        "padTop": 2,
        "padBottom":2,
        "alpha": 0.8
      },
      {
        "type": "DrawRegion",
        "suffix": "-rotator",
        "spinSprite": true,
        "rotateSpeed": 0.4,
        "warmup": true,
        "layer": 3
      },
      {
        "type": "DrawDefault",
        "layer": 4
      }
    ]
  }
}